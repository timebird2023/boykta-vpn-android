modules = ["nix", "python-base-3.13"]
[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Cloudflare Tunnel"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 bot.py"

[[workflows.workflow]]
name = "Cloudflare Tunnel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "/home/runner/workspace/cloudflared tunnel run --token $CLOUDFLARE_TOKEN"

[[ports]]
localPort = 25227
externalPort = 80

[userenv]

[userenv.shared]
DEVELOPER_ID = "7401831506"
