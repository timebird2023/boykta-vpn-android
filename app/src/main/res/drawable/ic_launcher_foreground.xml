<?xml version="1.0" encoding="utf-8"?>
<!--
  Boykta VPN launcher icon foreground — adaptive icon layer.
  Design: clean shield (cyan) with power-button symbol (pink) inside.
  Viewport 108×108, safe zone 72×72 centered at (54,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Shield filled — neon cyan ────────────────────────────────── -->
    <path
        android:fillColor="#00F2FE"
        android:pathData="M54,12 L26,23 L26,50 C26,68 38,79 54,85 C70,79 82,68 82,50 L82,23 Z"/>

    <!-- ── Shield inner — obsidian dark ────────────────────────────── -->
    <path
        android:fillColor="#0A0D13"
        android:pathData="M54,18 L31,28 L31,50 C31,66 41,75 54,80 C67,75 77,66 77,50 L77,28 Z"/>

    <!-- ── Power ring arc — neon pink, ~300° gap at top ────────────── -->
    <!--  Circle center (54,53), r=13.
          Gap endpoints at ±50° from 12-o'clock:
            left  = (54-13·sin50°, 53-13·cos50°) ≈ (44,45)
            right = (54+13·sin50°, 53-13·cos50°) ≈ (64,45)
          large-arc=1, sweep=1 → clockwise long path (300°)            -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FF0055"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M44,45 A13,13 0 1,1 64,45"/>

    <!-- ── Power vertical line — neon pink ─────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FF0055"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M54,36 L54,53"/>

    <!-- ── Small accent dot at shield tip ──────────────────────────── -->
    <path
        android:fillColor="#00F2FE"
        android:pathData="M54,76 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"/>

</vector>
