<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="Theme.BoykVpn" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/background</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_primary</item>

        <!-- Status bar & navigation bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowNoTitle">true</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_disabled</item>

        <!-- Card view defaults -->
        <item name="materialCardViewStyle">@style/Widget.BoykVpn.CardView</item>

        <!-- Button defaults -->
        <item name="materialButtonStyle">@style/Widget.BoykVpn.Button</item>

        <!-- Shape appearances -->
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.BoykVpn.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.BoykVpn.Large</item>
    </style>

    <!-- Splash / Launcher theme -->
    <style name="Theme.BoykVpn.Splash" parent="Theme.BoykVpn">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Card View Style -->
    <style name="Widget.BoykVpn.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.BoykVpn.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Button Outlined Style -->
    <style name="Widget.BoykVpn.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- Disconnect Button Style -->
    <style name="Widget.BoykVpn.Button.Disconnect" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/error</item>
        <item name="strokeColor">@color/error</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Shape appearances -->
    <style name="ShapeAppearance.BoykVpn.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.BoykVpn.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Dialog theme -->
    <style name="Theme.BoykVpn.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:colorBackground">@color/card</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Ad Dialog (full-screen) -->
    <style name="Theme.BoykVpn.Dialog.Ad" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:colorBackground">@color/dialog_background</item>
        <item name="android:windowBackground">@color/dialog_background</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
    </style>

</resources>
