<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE0A0E1A"
    android:fitsSystemWindows="true">

    <!-- Main Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ===== CLOSE BUTTON (top-right, hidden initially) ===== -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Close Ad"
            android:src="@drawable/ic_close"
            android:visibility="gone"
            app:backgroundTint="#FF4444"
            app:tint="@android:color/white"
            app:fabSize="mini"
            app:elevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible" />

        <!-- ===== AD IMAGE / GIF CAROUSEL ===== -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vpAd"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/surface_variant"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/adBottomSheet"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ===== TIMER PROGRESS BAR (overlaid at bottom of viewpager) ===== -->
        <ProgressBar
            android:id="@+id/pbTimer"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:max="100"
            android:progress="100"
            android:progressTint="@color/primary"
            android:progressBackgroundTint="@color/divider"
            app:layout_constraintBottom_toTopOf="@id/adBottomSheet"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ===== BOTTOM SHEET ===== -->
        <LinearLayout
            android:id="@+id/adBottomSheet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Countdown Text -->
            <TextView
                android:id="@+id/tvAdTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ad_close_in"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                tools:text="الإغلاق بعد 15 ث" />

            <!-- Viewpager Dots Indicator -->
            <LinearLayout
                android:id="@+id/dotsIndicator"
                android:layout_width="wrap_content"
                android:layout_height="8dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="14dp" />

            <!-- Clickable Ad Link -->
            <LinearLayout
                android:id="@+id/layoutAdLink"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_ad_link_button"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ad_tap_for_more"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
