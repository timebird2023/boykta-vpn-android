<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑 منشئ ومصدّر الكونفيغ"
            android:textColor="@color/primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- Protocol spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="البروتوكول"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />
        <Spinner
            android:id="@+id/spinnerProtocol"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/surface"
            android:popupBackground="@color/surface"
            android:layout_marginBottom="12dp" />

        <!-- Server Name -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="اسم السيرفر (يُعرض للمستخدم فقط)"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfigName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Host -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Host / IP السيرفر الحقيقي"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- SNI -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SNI (TLS Server Name)"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Host Header -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Host Header (CDN)"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHostHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Port -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Port"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- UUID -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="UUID / Password"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUuid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- WS Path -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="WS Path (e.g. /vless)"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Expiry duration -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="مدة الصلاحية"
                android:layout_marginEnd="8dp"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExpiry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <Spinner
                android:id="@+id/spinnerDurUnit"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@color/surface"
                android:popupBackground="@color/surface" />
        </LinearLayout>

        <!-- Custom toast / banner -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="رسالة عند الاتصال (اختياري)"
            android:layout_marginBottom="10dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCustomToast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Shadowsocks cipher (shown only for SS) -->
        <LinearLayout
            android:id="@+id/rowSsMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="SS Cipher (e.g. chacha20-ietf-poly1305)"
                android:layout_marginBottom="10dp"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSsMethod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Lock toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Switch
                android:id="@+id/switchLocked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="@color/primary"
                android:trackTint="#44FFFFFF" />

            <TextView
                android:id="@+id/tvLockStatus"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🔒 مشفر (Locked)"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Action buttons row: Cancel | Connect Directly | Export -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="إلغاء"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:strokeColor="@color/border" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnectDirectly"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="⚡ اتصال مباشر"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                app:backgroundTint="@color/neon_yellow"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📤 تصدير"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 Locked = AES-256-GCM | 🔓 Unlocked = JSON قابل للقراءة"
            android:textColor="@color/text_disabled"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
