<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 تصدير كونفيغ .boykta"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Protocol -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="البروتوكول"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>
        <Spinner
            android:id="@+id/spinnerProtocol"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/surface"
            android:popupBackground="@color/surface"
            android:layout_marginBottom="12dp"/>

        <!-- Server Name -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="اسم السيرفر (يُعرض للمستخدم فقط)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfigName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Host -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Host / IP السيرفر الحقيقي"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- SNI -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="SNI (TLS Server Name)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Host Header -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Host Header (WebSocket)"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHostHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Port + UUID in one row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.3"
                android:layout_marginEnd="8dp"
                android:hint="Port"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="25227"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.7"
                android:hint="UUID / Password"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/primary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUuid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textNoSuggestions"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Path -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="WebSocket Path"
            android:layout_marginBottom="12dp"
            app:boxStrokeColor="@color/primary"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="/"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Expiry -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="مدة الصلاحية (ساعات)"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/accent"
            app:hintTextColor="@color/accent">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="24"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="إلغاء"
                android:textColor="@color/text_secondary"
                app:strokeColor="@color/border"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📤 تصدير .boykta"
                android:textColor="#000000"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp"/>
        </LinearLayout>

        <!-- Security notice -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔒 الملف مشفر بـ AES-256-GCM — لا يمكن فتحه خارج التطبيق"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
