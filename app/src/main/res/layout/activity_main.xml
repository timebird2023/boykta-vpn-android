<?xml version="1.0" encoding="utf-8"?>
<!-- Root: DrawerLayout for side-navigation support -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <!-- ══ TOP BAR ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:background="@color/background_alt"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Hamburger menu button -->
                <ImageView
                    android:id="@+id/btnMenuDrawer"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_menu_drawer"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="قائمة" />

                <ImageView
                    android:id="@+id/ivShield"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/primary"
                    android:layout_marginStart="6dp"
                    android:contentDescription="logo" />

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="BOYKTA VPN"
                    android:textColor="@color/primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"
                    android:layout_marginStart="8dp" />

                <!-- Shield tint indicator (green when connected) -->
                <ImageView
                    android:id="@+id/ivStatusShield"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_shield"
                    app:tint="#FF0055"
                    android:contentDescription="connection status" />

            </LinearLayout>

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp"
                android:layout_marginStart="4dp">

                <View
                    android:id="@+id/dotStatus"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_status_dot" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="غير متصل"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ══ GLOWING CONNECT BUTTON ════════════════════════════════════ -->
        <FrameLayout
            android:id="@+id/connectWrapper"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Outer glow ring 1 -->
            <View
                android:id="@+id/ringOuter"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/bg_ring_outer"
                android:layout_gravity="center" />

            <!-- Outer glow ring 2 -->
            <View
                android:id="@+id/ringMid"
                android:layout_width="172dp"
                android:layout_height="172dp"
                android:background="@drawable/bg_ring_mid"
                android:layout_gravity="center" />

            <!-- Main button circle -->
            <LinearLayout
                android:id="@+id/btnConnectMain"
                android:layout_width="148dp"
                android:layout_height="148dp"
                android:background="@drawable/bg_connect_button"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:clickable="true"
                android:focusable="true">

                <!-- Vector drawable icon — NO emoji text -->
                <ImageView
                    android:id="@+id/ivConnectIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_play"
                    android:contentDescription="connect action" />

                <TextView
                    android:id="@+id/tvConnectLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECT"
                    android:textColor="@color/text_on_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- ══ SINGLE SERVER CARD ════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectedServer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/connectWrapper"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Country code badge (no emoji) -->
                <TextView
                    android:id="@+id/tvServerFlag"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:textColor="@color/primary"
                    android:gravity="center"
                    android:background="@color/surface_variant"
                    tools:text="DE"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Server Name -->
                <TextView
                    android:id="@+id/tvSelectedName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    tools:text="Germany #01"
                    app:layout_constraintTop_toTopOf="@id/tvServerFlag"
                    app:layout_constraintStart_toEndOf="@id/tvServerFlag"
                    app:layout_constraintEnd_toStartOf="@id/tvPingBadge" />

                <!-- LIVE PING BADGE -->
                <TextView
                    android:id="@+id/tvPingBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ping_badge"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    tools:text="32 ms"
                    app:layout_constraintTop_toTopOf="@id/tvServerFlag"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Protocol Badge -->
                <TextView
                    android:id="@+id/tvProtocolBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_protocol_badge"
                    android:paddingStart="7dp"
                    android:paddingEnd="7dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textColor="@color/primary"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginTop="6dp"
                    tools:text="TROJAN"
                    app:layout_constraintTop_toBottomOf="@id/tvSelectedName"
                    app:layout_constraintStart_toEndOf="@id/tvServerFlag"
                    android:layout_marginStart="12dp" />

                <!-- Countdown Timer -->
                <TextView
                    android:id="@+id/tvSelectedCountdown"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:gravity="end"
                    android:layout_marginTop="6dp"
                    tools:text="02d 14h:22m:11s"
                    app:layout_constraintTop_toBottomOf="@id/tvPingBadge"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvProtocolBadge"
                    android:layout_marginStart="8dp" />

                <!-- Tap hint -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="اضغط لتغيير السيرفر  ›"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/tvProtocolBadge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ══ UNLOCKED CONFIG PANEL ═════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUnlockedConfig"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="#0D1119"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#00F2FE55"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardSelectedServer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_key"
                        app:tint="#00F2FE"
                        android:contentDescription="unlocked" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  UNLOCKED CONFIG"
                        android:textColor="#00F2FE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <!-- Host -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Target"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                    <EditText
                        android:id="@+id/tvUnlockedHost"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="@android:color/transparent"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:textCursorDrawable="@null"
                        tools:text="boykta2-100891635133.europe-west1.run.app" />
                </LinearLayout>

                <!-- Path -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Path"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                    <EditText
                        android:id="@+id/tvUnlockedPath"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="@android:color/transparent"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:inputType="text"
                        android:singleLine="true"
                        android:textCursorDrawable="@null"
                        tools:text="/boykta" />
                </LinearLayout>

                <!-- SNI -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="SNI"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                    <EditText
                        android:id="@+id/tvUnlockedSni"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="@android:color/transparent"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:textCursorDrawable="@null"
                        tools:text="youtube.com" />
                </LinearLayout>

                <!-- Host Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="Host Hdr"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                    <EditText
                        android:id="@+id/tvUnlockedHostHeader"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="@android:color/transparent"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:textCursorDrawable="@null"
                        tools:text="boykta2-100891635133.europe-west1.run.app" />
                </LinearLayout>

                <!-- Reconnect button (unlocked config only) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReconnect"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="12dp"
                    android:text="حفظ وإعادة الاتصال"
                    android:textColor="@color/background"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="10dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ══ EMPTY STATE ════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/connectWrapper"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_server_off"
                app:tint="@color/text_secondary"
                android:contentDescription="no servers"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لا توجد سيرفرات — اضغط تحديث"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ══ LOADING INDICATOR ══════════════════════════════════════════ -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:visibility="gone"
            android:indeterminateTint="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/cardUnlockedConfig"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <!-- ══ BOTTOM ACTION BAR ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/background_alt"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Update/Refresh -->
            <LinearLayout
                android:id="@+id/btnBarUpdate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_refresh"
                    app:tint="@color/primary"
                    android:contentDescription="تحديث" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تحديث"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Logs -->
            <LinearLayout
                android:id="@+id/btnBarLogs"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_logs_terminal"
                    app:tint="@color/text_secondary"
                    android:contentDescription="سجل" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سجل"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <!-- Key / Config Creator -->
            <LinearLayout
                android:id="@+id/btnBarKey"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_key"
                    app:tint="@color/neon_yellow"
                    android:contentDescription="مفتاح" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مفتاح"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ══ LOG TERMINAL ═══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogTerminal"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/log_terminal_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardUnlockedConfig"
            app:layout_constraintBottom_toTopOf="@id/bottomBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_logs_terminal"
                        app:tint="@color/primary"
                        android:contentDescription="logs" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="LIVE TERMINAL LOG"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:layout_marginStart="6dp" />

                    <!-- Clear logs -->
                    <ImageView
                        android:id="@+id/btnClearLogs"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_trash"
                        app:tint="@color/text_secondary"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="مسح السجل"
                        android:layout_marginEnd="4dp" />

                    <TextView
                        android:id="@+id/btnCloseLog"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✕"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLogs"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="8dp"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_log_line" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ══ SIDE NAVIGATION DRAWER ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/navDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#0F1420"
        android:fitsSystemWindows="true">

        <!-- Drawer header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="20dp"
            android:background="#121622">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_shield"
                app:tint="#00F2FE"
                android:contentDescription="logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOYKTA VPN"
                android:textColor="#00F2FE"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0 — boykta vpn"
                android:textColor="#6B7FA8"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#00F2FE22"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- Drawer items -->

        <!-- Developer Channel -->
        <LinearLayout
            android:id="@+id/drawerItemTelegram"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_drawer_item"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_telegram"
                app:tint="#2AABEE"
                android:contentDescription="telegram" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="قناة المطورين"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <!-- Import Offline Config -->
        <LinearLayout
            android:id="@+id/drawerItemImport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_drawer_item"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_import"
                app:tint="#00F2FE"
                android:contentDescription="import" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="استيراد كونفيغ / سيرفر"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <!-- Live Terminal Logs -->
        <LinearLayout
            android:id="@+id/drawerItemLogs"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_drawer_item"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_logs_terminal"
                app:tint="#00F2FE"
                android:contentDescription="logs" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="سجل اللايف"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <!-- Share App -->
        <LinearLayout
            android:id="@+id/drawerItemShare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_drawer_item"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_share"
                app:tint="#00F2FE"
                android:contentDescription="share" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="مشاركة التطبيق"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <!-- Privacy Policy -->
        <LinearLayout
            android:id="@+id/drawerItemPrivacy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_drawer_item"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_privacy"
                app:tint="#00F2FE"
                android:contentDescription="privacy policy" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="سياسة الخصوصية والاستخدام"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <!-- Check Updates -->
        <LinearLayout
            android:id="@+id/drawerItemUpdate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_drawer_item"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_update_check"
                app:tint="#00F2FE"
                android:contentDescription="check updates" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="تحقق من التحديثات"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#00F2FE22"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp" />

        <!-- Exit -->
        <LinearLayout
            android:id="@+id/drawerItemExit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_drawer_item"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_exit"
                app:tint="#FF0055"
                android:contentDescription="exit" />

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="خروج"
                android:textColor="#FF0055"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginStart="14dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
