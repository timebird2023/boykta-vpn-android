<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- ══ HEADER CARD ══════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/headerCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/ivShield"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_shield"
                    android:contentDescription="VPN Shield"
                    app:tint="@color/primary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvAppTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="BOYKTA NET"
                    android:textColor="@color/primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"
                    android:layout_marginStart="12dp"
                    app:layout_constraintTop_toTopOf="@id/ivShield"
                    app:layout_constraintBottom_toTopOf="@id/tvStatus"
                    app:layout_constraintStart_toEndOf="@id/ivShield"
                    app:layout_constraintEnd_toStartOf="@id/dotStatus" />

                <View
                    android:id="@+id/dotStatus"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_status_dot"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/disconnected"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
                    app:layout_constraintStart_toEndOf="@id/ivShield"
                    app:layout_constraintEnd_toStartOf="@id/dotStatus" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ CONNECT PANEL ════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardConnectPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/headerCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- CONNECT / DISCONNECT button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnectMain"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="▶ CONNECT"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="14dp" />

                <!-- Ping badge (inline, next to connect button) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvPingLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PING"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvPingBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="…ms"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:background="@drawable/bg_ping_badge"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginTop="2dp"
                        tools:text="42ms" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ SELECTED SERVER CARD ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectedServer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardConnectPanel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="السيرفر المختار"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <TextView
                        android:id="@+id/tvSelectedName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="Germany Server 01" />

                    <TextView
                        android:id="@+id/tvProtocolBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_protocol_badge"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        tools:text="VLESS" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvSelectedCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    tools:text="01d 12h:30m:15s" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ LOG TERMINAL ══════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="#0A0C12"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cardSelectedServer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Log title bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="#0D1018">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot"
                        android:backgroundTint="#FF5F57" />
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot"
                        android:backgroundTint="#FEBC2E"
                        android:layout_marginStart="6dp" />
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot"
                        android:backgroundTint="#28C840"
                        android:layout_marginStart="6dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="LIVE LOG"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.15" />

                </LinearLayout>

                <!-- Log RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLogs"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:padding="10dp"
                    android:scrollbars="vertical"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ SERVER LIST LABEL ══════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvServersLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:text="السيرفرات المتاحة"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/cardLogs"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ══ EMPTY STATE ══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvServersLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_server_off"
                android:contentDescription="No servers"
                app:tint="@color/text_disabled"
                android:alpha="0.6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_servers"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginTop="12dp"
                android:gravity="center" />

        </LinearLayout>

        <!-- ══ SERVER RECYCLER VIEW ══════════════════════════════════════════ -->
        <!-- NOTE: ScrollView + RecyclerView — we use a NestedScrollView pattern
             but since the content is not huge, we set RecyclerView to wrap_content
             with nestedScrollingEnabled=false -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvServers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            android:scrollbars="none"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvServersLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_server"
            tools:itemCount="3" />

        <!-- ══ BOTTOM BUTTONS ════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/rvServers"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/update"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImport"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="📥 استيراد .boykta"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:strokeColor="@color/primary"
                app:cornerRadius="14dp" />

        </LinearLayout>

        <!-- ══ FAB: Admin Export ══════════════════════════════════════════════ -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabExport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="8dp"
            android:src="@drawable/ic_shield"
            android:contentDescription="تصدير كونفيغ"
            app:backgroundTint="@color/surface"
            app:tint="@color/primary"
            app:borderWidth="0dp"
            app:elevation="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomBar" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
