<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ══ TOP BAR ═══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:background="@color/background_alt"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivShield"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_shield"
                app:tint="@color/primary"
                android:contentDescription="logo" />

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="BOYKTA NET"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:fontFamily="monospace"
                android:layout_marginStart="10dp" />

            <!-- Speed counters -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_refresh"
                        app:tint="#00F2FE"
                        android:rotation="180"
                        android:contentDescription="upload" />
                    <TextView
                        android:id="@+id/tvUpSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 KB/s"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:layout_marginStart="3dp"
                        tools:text="1.2 MB/s" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_refresh"
                        app:tint="#FF0055"
                        android:contentDescription="download" />
                    <TextView
                        android:id="@+id/tvDownSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 KB/s"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:fontFamily="monospace"
                        android:layout_marginStart="3dp"
                        tools:text="5.4 MB/s" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Status row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <View
                android:id="@+id/dotStatus"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_status_dot" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="غير متصل"
                android:textColor="@color/accent"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══ GLOWING CONNECT BUTTON ════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/connectWrapper"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Outer glow ring 1 -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/bg_ring_outer"
            android:layout_gravity="center" />

        <!-- Outer glow ring 2 -->
        <View
            android:layout_width="172dp"
            android:layout_height="172dp"
            android:background="@drawable/bg_ring_mid"
            android:layout_gravity="center" />

        <!-- Main button circle -->
        <LinearLayout
            android:id="@+id/btnConnectMain"
            android:layout_width="148dp"
            android:layout_height="148dp"
            android:background="@drawable/bg_connect_button"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvConnectIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textColor="@color/text_on_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvConnectLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECT"
                android:textColor="@color/text_on_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.12"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- ══ SINGLE SERVER CARD ════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSelectedServer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/card"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/connectWrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Flag/Icon placeholder -->
            <TextView
                android:id="@+id/tvServerFlag"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="\uD83C\uDF10"
                android:textSize="24sp"
                android:gravity="center"
                android:background="@color/surface_variant"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Server Name -->
            <TextView
                android:id="@+id/tvSelectedName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                tools:text="Germany #01"
                app:layout_constraintTop_toTopOf="@id/tvServerFlag"
                app:layout_constraintStart_toEndOf="@id/tvServerFlag"
                app:layout_constraintEnd_toStartOf="@id/tvPingBadge" />

            <!-- LIVE PING BADGE -->
            <TextView
                android:id="@+id/tvPingBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ping_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:text="32 ms"
                app:layout_constraintTop_toTopOf="@id/tvServerFlag"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Protocol Badge -->
            <TextView
                android:id="@+id/tvProtocolBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_protocol_badge"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textColor="@color/primary"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginTop="6dp"
                tools:text="VLESS"
                app:layout_constraintTop_toBottomOf="@id/tvSelectedName"
                app:layout_constraintStart_toEndOf="@id/tvServerFlag"
                android:layout_marginStart="12dp" />

            <!-- Countdown Timer -->
            <TextView
                android:id="@+id/tvSelectedCountdown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:gravity="end"
                android:layout_marginTop="6dp"
                tools:text="02d 14h:22m:11s"
                app:layout_constraintTop_toBottomOf="@id/tvPingBadge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvProtocolBadge"
                android:layout_marginStart="8dp" />

            <!-- Tap hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اضغط لتغيير السيرفر  ›"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvProtocolBadge"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ══ UNLOCKED CONFIG PANEL (visible only for unlocked configs) ════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardUnlockedConfig"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="#0D1119"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#00F2FE55"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/cardSelectedServer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Header row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_key"
                    app:tint="#00F2FE"
                    android:contentDescription="unlocked" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  UNLOCKED CONFIG"
                    android:textColor="#00F2FE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <!-- Host -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Target"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/tvUnlockedHost"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    tools:text="khaledsurfing-404.duckdns.org" />
            </LinearLayout>

            <!-- Path -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Path"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/tvUnlockedPath"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    tools:text="/khaledsurfing" />
            </LinearLayout>

            <!-- SNI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="SNI"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/tvUnlockedSni"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    tools:text="youtube.com" />
            </LinearLayout>

            <!-- Host Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Host Hdr"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/tvUnlockedHostHeader"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:ellipsize="end"
                    android:maxLines="1"
                    tools:text="qwiklabs-gcp-02-33092c771ce4.ew.r.appspot.com" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ══ EMPTY STATE (no servers) ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/connectWrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="لا توجد سيرفرات — اضغط تحديث"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <!-- ══ LOADING INDICATOR ══════════════════════════════════════════════════ -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:visibility="gone"
        android:indeterminateTint="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/cardUnlockedConfig"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- ══ BOTTOM ACTION BAR ═════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/background_alt"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Update/Refresh -->
        <LinearLayout
            android:id="@+id/btnBarUpdate"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_refresh"
                app:tint="@color/primary"
                android:contentDescription="تحديث" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تحديث"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Logs -->
        <LinearLayout
            android:id="@+id/btnBarLogs"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_logs_terminal"
                app:tint="@color/text_secondary"
                android:contentDescription="سجل" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سجل"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Key / Config Creator -->
        <LinearLayout
            android:id="@+id/btnBarKey"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_key"
                app:tint="@color/neon_yellow"
                android:contentDescription="مفتاح" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مفتاح"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Telegram -->
        <LinearLayout
            android:id="@+id/btnBarTelegram"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_telegram"
                app:tint="#2AABEE"
                android:contentDescription="تلغرام" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="قناتنا"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <!-- Exit -->
        <LinearLayout
            android:id="@+id/btnBarExit"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="6dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_exit"
                app:tint="@color/accent"
                android:contentDescription="خروج" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خروج"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══ LOG TERMINAL (hidden by default, toggled via Logs button) ═════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLogTerminal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/log_terminal_bg"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/cardUnlockedConfig"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_logs_terminal"
                    app:tint="@color/primary"
                    android:contentDescription="live log" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="  LIVE LOG"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnCloseLog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLogs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_log_line" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
