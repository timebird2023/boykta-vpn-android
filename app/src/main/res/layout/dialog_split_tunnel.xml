<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F131D"
    android:minHeight="400dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvSplitTunnelTitle"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Split Tunneling"
            android:textColor="#00F2FE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.05" />

        <ImageView
            android:id="@+id/btnSplitTunnelClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            app:tint="#5A6E96"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="إغلاق" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="التطبيقات المحددة ستتجاوز نفق VPN وتتصل بالإنترنت مباشرةً"
        android:textColor="#5A6E96"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="10dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#162033" />

    <ProgressBar
        android:id="@+id/progressSplitTunnel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#00F2FE"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:visibility="visible" />

    <ListView
        android:id="@+id/listSplitTunnel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:divider="#162033"
        android:dividerHeight="1dp"
        android:choiceMode="multipleChoice"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

</LinearLayout>
